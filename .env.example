# Token du bot Telegram (obtenu via @BotFather)
TELEGRAM_TOKEN=your_telegram_bot_token_here

# Clé API Anthropic
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# URL publique du service (Railway la génère automatiquement, ex: https://monapp.up.railway.app)
# Décommentez et remplissez si vous n'utilisez pas Railway ou si le webhook ne s'enregistre pas
# BASE_URL=https://monapp.up.railway.app

# --- MCP (optionnel) ---
# MCP_SERVER_URL=https://demo-odoo-mcp.netlify.app/mcp
# MCP_SERVER_NAME=odoo

# --- Personnalisation de l'agent (optionnel) ---
# SYSTEM_PROMPT=Tu es un assistant IA serviable et concis. Réponds toujours dans la langue de l'utilisateur.
# WELCOME_MESSAGE=Bonjour ! Je suis votre assistant IA. Comment puis-je vous aider ?
# CLAUDE_MODEL=claude-sonnet-4-6
# MAX_TOKENS=1024
